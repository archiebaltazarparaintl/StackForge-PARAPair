/// =========================================================
/// PARA_PAIR ENTERPRISE MESSAGING & REALTIME MODULE
/// Module: Messaging / Presence / WebSockets / Delivery
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum ConversationType {
  DIRECT_MATCH
  GROUP
  SYSTEM
  SUPPORT
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  LOCKED
  DELETED
}

enum ParticipantRole {
  MEMBER
  ADMIN
  MODERATOR
  OWNER
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  SYSTEM
  EVENT
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  DELETED
}

enum PresenceStatus {
  ONLINE
  AWAY
  DO_NOT_DISTURB
  OFFLINE
}

enum AttachmentScanStatus {
  PENDING
  CLEAN
  INFECTED
  BLOCKED
}

enum RealtimeConnectionStatus {
  CONNECTED
  DISCONNECTED
  TERMINATED
}

/// =========================================================
/// CONVERSATIONS
/// =========================================================

model Conversation {
  id                              String                        @id @default(uuid())

  type                            ConversationType              @default(DIRECT_MATCH)

  status                          ConversationStatus            @default(ACTIVE)

  matchId                         String?                       @unique

  title                           String?

  lastMessageId                   String?
  lastMessageAt                   DateTime?

  totalMessages                   Int                           @default(0)

  encryptionVersion               String?

  metadata                        Json?

  createdAt                       DateTime                      @default(now())
  updatedAt                       DateTime                      @updatedAt
  deletedAt                       DateTime?

  /// ---------- Relations ----------
  match                           Match?                        @relation(fields: [matchId], references: [id])

  participants                    ConversationParticipant[]
  messages                        Message[]

  typingIndicators                TypingIndicator[]
  websocketConnections            WebSocketConnection[]

  @@index([type])
  @@index([status])
  @@index([lastMessageAt])
  @@index([deletedAt])
}

/// =========================================================
/// CONVERSATION PARTICIPANTS
/// =========================================================

model ConversationParticipant {
  id                              String                        @id @default(uuid())

  conversationId                  String
  personaId                       String

  role                            ParticipantRole              @default(MEMBER)

  unreadCount                     Int                           @default(0)

  lastReadMessageId               String?
  lastReadAt                      DateTime?

  notificationsMuted              Boolean                       @default(false)

  isArchived                      Boolean                       @default(false)

  joinedAt                        DateTime                      @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
  conversation                    Conversation                  @relation(fields: [conversationId], references: [id])

  persona                         Persona                       @relation(fields: [personaId], references: [id])

  @@unique([conversationId, personaId])

  @@index([conversationId])
  @@index([personaId])
  @@index([lastReadAt])
}

/// =========================================================
/// MESSAGES
/// =========================================================

model Message {
  id                              String                        @id @default(uuid())

  conversationId                  String

  senderPersonaId                 String?

  type                            MessageType                  @default(TEXT)

  status                          MessageStatus                @default(PENDING)

  /// ---------- Content ----------
  encryptedPayload                Bytes?

  plainTextPreview                String?

  /// ---------- Moderation ----------
  moderationStatus                String?

  isEdited                        Boolean                       @default(false)
  editedAt                        DateTime?

  /// ---------- Lifecycle ----------
  deliveredAt                     DateTime?
  readAt                          DateTime?

  deletedAt                       DateTime?

  expiresAt                       DateTime?

  /// ---------- Threading ----------
  replyToMessageId                String?

  /// ---------- Metadata ----------
  metadata                        Json?

  createdAt                       DateTime                      @default(now())
  updatedAt                       DateTime                      @updatedAt

  /// ---------- Relations ----------
  conversation                    Conversation                  @relation(fields: [conversationId], references: [id])

  senderPersona                   Persona?                      @relation(fields: [senderPersonaId], references: [id])

  attachments                     MessageAttachment[]

  receipts                        MessageReceipt[]

  replyToMessage                  Message?                      @relation("MessageReplies", fields: [replyToMessageId], references: [id])

  replies                         Message[]                     @relation("MessageReplies")

  reactions                       MessageReaction[]

  moderationEvents                MessageModerationEvent[]

  @@index([conversationId])
  @@index([senderPersonaId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([replyToMessageId])

  // ── auto-injected back-relations ──
  messageDeliveryQueue  MessageDeliveryQueue[]
  moderationCase  ModerationCase[]
}

/// =========================================================
/// MESSAGE ATTACHMENTS
/// =========================================================

model MessageAttachment {
  id                              String                        @id @default(uuid())

  messageId                       String

  storageKey                      String

  originalFileName                String?

  mimeType                        String

  fileSize                        Int

  checksum                        String

  width                           Int?
  height                          Int?

  durationSeconds                 Int?

  /// ---------- Security ----------
  malwareScanStatus               AttachmentScanStatus          @default(PENDING)

  moderationStatus                String?

  /// ---------- Metadata ----------
  metadata                        Json?

  createdAt                       DateTime                      @default(now())

  /// ---------- Relations ----------
  message                         Message                       @relation(fields: [messageId], references: [id])

  @@index([messageId])
  @@index([malwareScanStatus])
}

/// =========================================================
/// MESSAGE RECEIPTS
/// =========================================================

model MessageReceipt {
