model ModerationCase {
  id                              String                      @id @default(uuid())

  targetPersonaId                 String?

  targetMessageId                 String?

  targetWorkspaceId               String?

  reportedByPersonaId             String?

  status                          ModerationCaseStatus        @default(OPEN)

  severity                        RiskLevel                   @default(MEDIUM)

  category                        String

  description                     String?

  assignedModeratorId             String?

  resolutionSummary               String?

  openedAt                        DateTime                    @default(now())

  resolvedAt                      DateTime?

  metadata                        Json?

  /// ---------- Relations ----------
  targetPersona                   Persona?                    @relation(fields: [targetPersonaId], references: [id])

  targetMessage                   Message?                    @relation(fields: [targetMessageId], references: [id])

  targetWorkspace                 Workspace?                  @relation(fields: [targetWorkspaceId], references: [id])

  reportedByPersona               Persona?                    @relation("ModerationReporter", fields: [reportedByPersonaId], references: [id])

  assignedModerator               User?                       @relation("ModerationAssignee", fields: [assignedModeratorId], references: [id])

