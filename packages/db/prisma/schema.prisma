  phoneVerifications      PhoneVerification[]

  otpChallenges           OTPChallenge[]

  mfaMethods              MFAMethod[]
  backupCodes             BackupCode[]

  passwordHistory         PasswordHistory[]
  recoveryRequests        AccountRecoveryRequest[]

  authEvents              AuthEvent[]
  securityEvents          SecurityEvent[]

  auditLogs               AuditLog[]

  riskSignals             UserRiskSignal[]

  userConsents            UserConsent[]

  @@index([accountStatus])
  @@index([verificationLevel])
  @@index([deletedAt])
  @@index([trustScore])
  @@index([createdAt])

  // ── auto-injected back-relations ──
  analyticsEvent  AnalyticsEvent[]
  analyticsSession  AnalyticsSession[]
  featureFlagAssignment  FeatureFlagAssignment[]
  errorLog  ErrorLog[]
  auditExportJob  AuditExportJob[]
  recoveryJob  RecoveryJob[]
  disasterRecoveryTest  DisasterRecoveryTest[]
  domainEvent  DomainEvent[]
  workflowExecution  WorkflowExecution[]
  commandExecution  CommandExecution[]
  idempotencyKey  IdempotencyKey[]
  userDeviceFingerprint  UserDeviceFingerprint[]
  userReputation  UserReputation[]
  threatSignal  ThreatSignal[]
  fraudInvestigationCase  FraudInvestigationCase[]
  fraudInvestigationCase_FraudModerator  FraudInvestigationCase[]  @relation("FraudModerator")
  abuseEnforcementAction_AbuseTargetUser  AbuseEnforcementAction[]  @relation("AbuseTargetUser")
  abuseEnforcementAction_AbuseActionCreator  AbuseEnforcementAction[]  @relation("AbuseActionCreator")
  linkedAccount  LinkedAccount[]
  userVelocityMetric  UserVelocityMetric[]
  shadowBan  ShadowBan[]
  riskScoreHistory  RiskScoreHistory[]
  workspaceMember  WorkspaceMember[]
  workspaceMember_WorkspaceInviter  WorkspaceMember[]  @relation("WorkspaceInviter")
  workspaceInvitation  WorkspaceInvitation[]
  workspaceApiKey  WorkspaceApiKey[]
  workspaceAuditLog  WorkspaceAuditLog[]
  complianceDocument  ComplianceDocument[]
  activityFeedItem_FeedOwner  ActivityFeedItem[]  @relation("FeedOwner")
  activityFeedItem_FeedActor  ActivityFeedItem[]  @relation("FeedActor")
  realtimeConnection  RealtimeConnection[]
  messageDeliveryQueue  MessageDeliveryQueue[]
  apiKey  ApiKey[]
  mediaAsset  MediaAsset[]
  userConsentRecord  UserConsentRecord[]
  privacyPolicyVersion  PrivacyPolicyVersion[]
  termsOfServiceVersion  TermsOfServiceVersion[]
  dataSubjectRequest  DataSubjectRequest[]
  userDataExport  UserDataExport[]
  legalHold  LegalHold[]
  lawEnforcementRequest  LawEnforcementRequest[]
  cookieConsentRecord  CookieConsentRecord[]
  trustedDevice  TrustedDevice[]
  privacyRequest  PrivacyRequest[]
  moderationCase_ModerationAssignee  ModerationCase[]  @relation("ModerationAssignee")
  moderationAction  ModerationAction[]
  fraudCase  FraudCase[]
  fraudCase_FraudInvestigator  FraudCase[]  @relation("FraudInvestigator")
}

/// =========================================================
/// DEVICES
/// =========================================================

model Device {
  id                      String              @id @default(uuid())

  userId                  String

  /// ---------- Fingerprinting ----------
  fingerprintHash         String
  hardwareHash            String?

  /// ---------- Device Info ----------
  deviceName              String?
  deviceType              String?

  osName                  String?
  osVersion               String?

  browserName             String?
  browserVersion          String?

  /// ---------- Security ----------
  trustLevel              DeviceTrustLevel    @default(UNKNOWN)

  isEmulator              Boolean             @default(false)
  isRooted                Boolean             @default(false)
  isJailbroken            Boolean             @default(false)

  /// ---------- Metadata ----------
  firstSeenAt             DateTime            @default(now())
  lastSeenAt              DateTime            @default(now())

  /// ---------- Relations ----------
  user                    User                @relation(fields: [userId], references: [id])

  sessions                Session[]
  securityEvents          SecurityEvent[]

  @@index([userId])
  @@index([fingerprintHash])
  @@index([trustLevel])
}

/// =========================================================
/// SESSIONS
/// =========================================================

model Session {
  id                      String              @id @default(uuid())

  userId                  String
  deviceId                String

  status                  SessionStatus       @default(ACTIVE)

  /// ---------- Security ----------
  ipAddress               String
  geoCountry              String?
  geoRegion               String?
  geoCity                 String?

  userAgent               String

  /// ---------- Session Lifecycle ----------
  createdAt               DateTime            @default(now())
  lastUsedAt              DateTime            @default(now())

  expiresAt               DateTime
  revokedAt               DateTime?

  /// ---------- Relations ----------
  user                    User                @relation(fields: [userId], references: [id])
  device                  Device              @relation(fields: [deviceId], references: [id])

  refreshTokens           RefreshToken[]

  @@index([userId])
  @@index([deviceId])
  @@index([status])
  @@index([expiresAt])
  @@index([lastUsedAt])
}

