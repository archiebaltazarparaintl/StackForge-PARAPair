/// =========================================================

model UserVelocityMetric {
  id                              String                        @id @default(uuid())

  userId                          String

  metricKey                       String

  metricValue                     Float

  aggregationWindow               String

  calculatedAt                    DateTime                      @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
  user                            User                          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([metricKey])
  @@index([calculatedAt])
}

/// =========================================================
/// SHADOW BAN REGISTRY
/// =========================================================

model ShadowBan {
  id                              String                        @id @default(uuid())

  userId                          String                        @unique

  reason                          String?

  hiddenFromDiscovery             Boolean                       @default(true)

  hiddenFromMessaging             Boolean                       @default(false)

  hiddenFromRecommendations       Boolean                       @default(true)

  imposedAt                       DateTime                      @default(now())

  expiresAt                       DateTime?

  liftedAt                        DateTime?

  metadata                        Json?

  /// ---------- Relations ----------
  user                            User                          @relation(fields: [userId], references: [id])

  @@index([expiresAt])
}

/// =========================================================
/// RISK SCORING HISTORY
/// =========================================================

model RiskScoreHistory {
  id                              String                        @id @default(uuid())

  userId                          String

  previousRiskScore               Float?

  newRiskScore                    Float

  riskFactors                     Json?

  calculatedAt                    DateTime                      @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
  user                            User                          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([calculatedAt])
}

/// =========================================================
/// PARA_PAIR ENTERPRISE GOVERNANCE & ORGANIZATION MODULE
/// Module: Governance / Enterprise Controls / B2B / Admin
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum WorkspaceType {
  PERSONAL
  BUSINESS
  ENTERPRISE
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  LOCKED
  DELETED
}

enum WorkspaceGovernanceRole {
  OWNER
  ADMIN
  MANAGER
  MODERATOR
  BILLING_ADMIN
  ANALYST
  MEMBER
  READONLY
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  REVOKED
}

enum AuditActionSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApiEnvironment {
  SANDBOX
  PRODUCTION
}

enum FeatureAccessStatus {
  ENABLED
  DISABLED
  LIMITED
}

/// =========================================================
/// WORKSPACES
/// =========================================================

model Workspace {
  id                              String                          @id @default(uuid())

  workspaceKey                    String                          @unique

  type                            WorkspaceType                  @default(BUSINESS)

  status                          WorkspaceStatus                @default(ACTIVE)

  displayName                     String

  legalBusinessName               String?

  slug                            String                          @unique

  primaryEmail                    String?

  primaryPhone                    String?

  websiteUrl                      String?

  taxId                           String?

  registrationNumber              String?

  country                         String?

  timezone                        String?

  logoAssetId                     String?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt
  deletedAt                       DateTime?

  /// ---------- Relations ----------
  members                         WorkspaceMember[]

  invitations                     WorkspaceInvitation[]

  featureEntitlements             WorkspaceFeatureEntitlement[]

  apiKeys                         WorkspaceApiKey[]              @relation(fields: [workspaceId], references: [id])

  auditLogs                       WorkspaceAuditLog[]

  complianceDocuments             ComplianceDocument[]

  billingCustomer                 BillingCustomer?

  webhookEndpoints                WebhookEndpoint[]

  moderationCases                 ModerationCase[]

  legalHolds                      LegalHold[]

  analyticsEvents                 AnalyticsEvent[]

  securityEvents                  SecurityEvent[]

  @@index([workspaceKey])
  @@index([slug])
  @@index([status])
  @@index([deletedAt])

  // ── auto-injected back-relations ──
  recommendationCandidate  RecommendationCandidate[]
  featureFlagAssignment  FeatureFlagAssignment[]
  errorLog  ErrorLog[]
  domainEvent  DomainEvent[]
  workflowExecution  WorkflowExecution[]
  bankAccount  BankAccount[]
  walletAccount  WalletAccount[]
  payout  Payout[]
  persona  Persona[]
  listing  Listing[]
  workspaceCustomRole  WorkspaceCustomRole[]
  workspacePermission  WorkspacePermission[]
  workspaceComplianceRecord  WorkspaceComplianceRecord[]
}

/// =========================================================
/// WORKSPACE MEMBERS
/// =========================================================

model WorkspaceMember {
  id                              String                          @id @default(uuid())

  workspaceId                     String

  userId                          String

  role                            WorkspaceGovernanceRole           @default(MEMBER)

  invitedByUserId                 String?

  joinedAt                        DateTime                       @default(now())

  removedAt                       DateTime?

  metadata                        Json?

  /// ---------- Relations ----------
  workspace                       Workspace                      @relation(fields: [workspaceId], references: [id])

  user                            User                           @relation(fields: [userId], references: [id])

  invitedByUser                   User?                          @relation("WorkspaceInviter", fields: [invitedByUserId], references: [id])

  @@unique([workspaceId, userId])

  @@index([workspaceId])
  @@index([userId])
  @@index([role])

  // ── auto-injected back-relations ──
  workspaceMemberRole  WorkspaceMemberRole[]
}

/// =========================================================
/// WORKSPACE INVITATIONS
/// =========================================================

model WorkspaceInvitation {
  id                              String                          @id @default(uuid())

  workspaceId                     String

  invitedEmail                    String

  invitedRole                     WorkspaceGovernanceRole

  invitationTokenHash             String                          @unique

  status                          InvitationStatus              @default(PENDING)

  expiresAt                       DateTime

  acceptedAt                      DateTime?

  revokedAt                       DateTime?

  invitedByUserId                 String?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  workspace                       Workspace                      @relation(fields: [workspaceId], references: [id])

  invitedByUser                   User?                          @relation(fields: [invitedByUserId], references: [id])

  @@index([workspaceId])
  @@index([status])
  @@index([expiresAt])
}

/// =========================================================
/// WORKSPACE FEATURE ENTITLEMENTS
/// =========================================================

model WorkspaceFeatureEntitlement {
  id                              String                          @id @default(uuid())

  workspaceId                     String

  featureKey                      String

  status                          FeatureAccessStatus           @default(ENABLED)

  usageLimit                      Int?

  currentUsage                    Int                            @default(0)

  resetAt                         DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  workspace                       Workspace                      @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, featureKey])

  @@index([workspaceId])
  @@index([featureKey])
}

/// =========================================================
/// ENTERPRISE API KEYS
/// =========================================================

model WorkspaceApiKey {
  id                              String                          @id @default(uuid())

  workspaceId                     String

  environment                     ApiEnvironment                @default(PRODUCTION)

  keyPrefix                       String

  keyHash                         String                          @unique

  displayName                     String

  scopes                          String[]

  allowedIps                      String[]

  lastUsedAt                      DateTime?

  expiresAt                       DateTime?

  revokedAt                       DateTime?

  createdByUserId                 String?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  workspace                       Workspace                      @relation(fields: [workspaceId], references: [id])

  createdByUser                   User?                          @relation(fields: [createdByUserId], references: [id])

  accessAudits                    ApiAccessAudit[]

  @@index([workspaceId])
  @@index([expiresAt])
  @@index([revokedAt])
}

/// =========================================================
/// WORKSPACE AUDIT LOGS
/// =========================================================

model WorkspaceAuditLog {
  id                              String                          @id @default(uuid())

  workspaceId                     String

  actorUserId                     String?

  action                          String

  entityType                      String

  entityId                        String?

  severity                        AuditActionSeverity           @default(LOW)

  ipAddress                       String?

  userAgent                       String?

  metadata                        Json?

  occurredAt                      DateTime                        @default(now())

  /// ---------- Relations ----------
  workspace                       Workspace                      @relation(fields: [workspaceId], references: [id])

  actorUser                       User?                           @relation(fields: [actorUserId], references: [id])

  @@index([workspaceId])
  @@index([actorUserId])
  @@index([action])
  @@index([occurredAt])
}

/// =========================================================
/// COMPLIANCE DOCUMENTS
/// =========================================================

model ComplianceDocument {
  id                              String                          @id @default(uuid())

  workspaceId                     String

  documentType                    String

  documentVersion                 String

  documentStorageKey              String

  checksum                        String?

  uploadedByUserId                String?

  effectiveAt                     DateTime?

  expiresAt                       DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  workspace                       Workspace                      @relation(fields: [workspaceId], references: [id])

  uploadedByUser                  User?                           @relation(fields: [uploadedByUserId], references: [id])

  @@index([workspaceId])
  @@index([documentType])
  @@index([expiresAt])
}

/// =========================================================
/// PARA_PAIR HIGH-SCALE PARTITIONING & THROUGHPUT MODULE
/// Module: Massive Scale / Partitioning / Feed Scaling
/// Classification: 1M+ Concurrent User Ready
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum PartitionStrategy {
  RANGE
  HASH
  LIST
}

enum FeedItemType {
  MATCH
  MESSAGE
  LISTING
  SYSTEM
  NOTIFICATION
  RECOMMENDATION
}

enum FeedVisibility {
  PRIVATE
  CONNECTIONS
  PUBLIC
}

enum CacheEntryStatus {
  ACTIVE
  EXPIRED
  INVALIDATED
}

/// =========================================================
/// PARTITION REGISTRY
/// =========================================================

model PartitionRegistry {
  id                              String                        @id @default(uuid())

  tableName                       String

  partitionName                   String                        @unique

  strategy                        PartitionStrategy

  partitionKey                    String

  boundaryStart                   DateTime?

  boundaryEnd                     DateTime?

  shardIdentifier                 String?

  active                          Boolean                       @default(true)

  metadata                        Json?

  createdAt                       DateTime                      @default(now())

  @@index([tableName])
  @@index([active])
}

/// =========================================================
/// DISTRIBUTED COUNTERS
/// =========================================================

model DistributedCounter {
  id                              String                        @id @default(uuid())

  counterKey                      String                        @unique

  counterValue                    BigInt                        @default(0)

  lastAggregatedAt                DateTime?

  metadata                        Json?

  updatedAt                       DateTime                      @updatedAt

  @@index([updatedAt])
}

/// =========================================================
/// USER ACTIVITY FEED
/// =========================================================

model ActivityFeedItem {
  id                              String                        @id @default(uuid())

  ownerUserId                     String

  actorUserId                     String?

  itemType                        FeedItemType

  visibility                      FeedVisibility               @default(PRIVATE)

  entityType                      String

  entityId                        String

  rankingScore                    Float?

  payload                         Json?

  expiresAt                       DateTime?

  createdAt                       DateTime                      @default(now())

  /// ---------- Relations ----------
  ownerUser                       User                          @relation("FeedOwner", fields: [ownerUserId], references: [id])

  actorUser                       User?                         @relation("FeedActor", fields: [actorUserId], references: [id])

  @@index([ownerUserId, createdAt])
  @@index([itemType])
  @@index([rankingScore])
  @@index([expiresAt])
}

/// =========================================================
/// HOT CACHE REGISTRY
/// =========================================================

model CacheEntry {
  id                              String                        @id @default(uuid())

  cacheKey                        String                        @unique

  cacheNamespace                  String

  cacheStatus                     CacheEntryStatus             @default(ACTIVE)

  payload                         Json

  ttlSeconds                      Int

  invalidatedAt                   DateTime?

  expiresAt                       DateTime

  createdAt                       DateTime                      @default(now())

  @@index([cacheNamespace])
  @@index([expiresAt])
  @@index([cacheStatus])
}

/// =========================================================
/// RATE LIMIT BUCKETS
/// =========================================================

model RateLimitBucket {
  id                              String                        @id @default(uuid())

  bucketKey                       String                        @unique

  requestCount                    Int                           @default(0)

  windowStartedAt                 DateTime

  expiresAt                       DateTime

  metadata                        Json?

  createdAt                       DateTime                      @default(now())

  @@index([expiresAt])
}

/// =========================================================
/// WEBSOCKET CONNECTION REGISTRY
/// =========================================================

model RealtimeConnection {
  id                              String                        @id @default(uuid())

  userId                          String?

  connectionId                    String                        @unique

  region                          String?

  nodeIdentifier                  String?

  ipAddress                       String?

  connectedAt                     DateTime                      @default(now())

  disconnectedAt                  DateTime?

  lastHeartbeatAt                 DateTime?

  metadata                        Json?

  /// ---------- Relations ----------
  user                            User?                         @relation(fields: [userId], references: [id])

  subscriptions                   RealtimeSubscription[]

  @@index([userId])
  @@index([connectedAt])
  @@index([lastHeartbeatAt])
}

/// =========================================================
/// REALTIME SUBSCRIPTIONS
/// =========================================================

model RealtimeSubscription {
  id                              String                        @id @default(uuid())

  realtimeConnectionId            String

  channelName                     String

  subscribedAt                    DateTime                      @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
