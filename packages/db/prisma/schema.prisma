/// =========================================================

model WorkspaceMemberRole {
  id                          String                  @id @default(uuid())

  workspaceMemberId           String
  customRoleId                String

  assignedAt                  DateTime                @default(now())

  /// ---------- Relations ----------
  workspaceMember             WorkspaceMember         @relation(fields: [workspaceMemberId], references: [id])

  customRole                  WorkspaceCustomRole     @relation(fields: [customRoleId], references: [id])

  @@unique([workspaceMemberId, customRoleId])

  @@index([workspaceMemberId])
  @@index([customRoleId])
}

/// =========================================================
/// PERMISSIONS
/// =========================================================

model WorkspacePermission {
  id                          String                  @id @default(uuid())

  workspaceId                 String

  permissionKey               String

  description                 String?

  createdAt                   DateTime                @default(now())

  /// ---------- Relations ----------
  workspace                   Workspace               @relation(fields: [workspaceId], references: [id])

  rolePermissions             WorkspaceRolePermission[]

  @@unique([workspaceId, permissionKey])

  @@index([workspaceId])
}

/// =========================================================
/// ROLE PERMISSIONS
/// =========================================================

model WorkspaceRolePermission {
  id                          String                  @id @default(uuid())

  customRoleId                String
  permissionId                String

  effect                      PermissionEffect        @default(ALLOW)

  createdAt                   DateTime                @default(now())

  /// ---------- Relations ----------
  customRole                  WorkspaceCustomRole     @relation(fields: [customRoleId], references: [id])

  permission                  WorkspacePermission     @relation(fields: [permissionId], references: [id])

  @@unique([customRoleId, permissionId])

  @@index([customRoleId])
  @@index([permissionId])
}

