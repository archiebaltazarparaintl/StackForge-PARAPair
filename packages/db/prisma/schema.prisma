  personaB                        Persona                   @relation("MatchPersonaB", fields: [personaBId], references: [id])

  matchScore                      MatchScore?               @relation(fields: [matchScoreId], references: [id])

  createdBySwipe                  SwipeEvent?               @relation("MatchCreationSwipe", fields: [createdBySwipeId], references: [id])

  interactions                    MatchInteraction[]

  conversation                    Conversation?

  @@unique([personaAId, personaBId])

