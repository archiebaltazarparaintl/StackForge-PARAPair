
generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// ================= MODULES =================

/// =========================================================
/// PARA_PAIR ENTERPRISE AI MATCHING & RECOMMENDATION MODULE
/// Module: AI / Recommendation / Ranking / Personalization
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum RecommendationType {
  MATCH
  LISTING
  BUSINESS
  PERSONA
  CONTENT
}

enum RecommendationStatus {
  PENDING
  ACTIVE
  DISMISSED
  ACCEPTED
  EXPIRED
}

enum MLModelStatus {
  TRAINING
  ACTIVE
  DEPRECATED
  DISABLED
}

enum EmbeddingType {
  PROFILE
  MESSAGE
  LISTING
  INTEREST
  SKILL
}

enum FeedbackType {
  LIKE
  DISLIKE
  HIDE
  REPORT
  BOOST
}

/// =========================================================
/// RECOMMENDATION CANDIDATES
/// =========================================================

model RecommendationCandidate {
  id                              String                        @id @default(uuid())

  personaId                       String

  targetPersonaId                 String?

  targetListingId                 String?

  targetBusinessId                String?

  recommendationType              RecommendationType

  recommendationStatus            RecommendationStatus         @default(PENDING)

  rankingScore                    Float

  compatibilityScore              Float?

  relevanceScore                  Float?

  diversityScore                  Float?

  freshnessScore                  Float?

  generatedByModelVersion         String?

  explanationPayload              Json?

  expiresAt                       DateTime?

  generatedAt                     DateTime                      @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
  persona                         Persona                       @relation("RecommendationOwner", fields: [personaId], references: [id])

  targetPersona                   Persona?                      @relation("RecommendationTargetPersona", fields: [targetPersonaId], references: [id])

  targetListing                   Listing?                      @relation(fields: [targetListingId], references: [id])

  targetBusiness                  Workspace?                    @relation(fields: [targetBusinessId], references: [id])

  feedback                        RecommendationFeedback[]

  @@index([personaId])
  @@index([targetPersonaId])
  @@index([targetListingId])
  @@index([recommendationType])
  @@index([rankingScore])
  @@index([generatedAt])
}

/// =========================================================
/// RECOMMENDATION FEEDBACK
/// =========================================================

model RecommendationFeedback {
  id                              String                        @id @default(uuid())

  recommendationCandidateId       String

  personaId                       String

  feedbackType                    FeedbackType

  feedbackScore                   Float?

  feedbackReason                  String?

  createdAt                       DateTime                      @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
  recommendationCandidate         RecommendationCandidate       @relation(fields: [recommendationCandidateId], references: [id])

  persona                         Persona                       @relation(fields: [personaId], references: [id])

  @@index([recommendationCandidateId])
  @@index([personaId])
  @@index([feedbackType])
}

/// =========================================================
/// EMBEDDINGS
/// =========================================================

model EmbeddingVector {
  id                              String                        @id @default(uuid())

  embeddingType                   EmbeddingType

  entityId                        String

  modelVersion                    String

  vectorDimensions                Int

  vectorProvider                  String

  vectorStorageKey                String

  checksum                        String?

  generatedAt                     DateTime                      @default(now())

  metadata                        Json?

  @@unique([embeddingType, entityId, modelVersion])

  @@index([embeddingType])
  @@index([entityId])
  @@index([generatedAt])
}

/// =========================================================
/// MATCH SCORING
/// =========================================================

model MatchScore {
  id                              String                        @id @default(uuid())

  personaAId                      String

  personaBId                      String

  compatibilityScore              Float

  communicationScore              Float?

  intentScore                     Float?

  trustScore                      Float?

  activityScore                   Float?

  behavioralScore                 Float?

  modelVersion                    String

  scoredAt                        DateTime                      @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
  personaA                        Persona                       @relation("MatchScorePersonaA", fields: [personaAId], references: [id])

  personaB                        Persona                       @relation("MatchScorePersonaB", fields: [personaBId], references: [id])

  @@unique([personaAId, personaBId])

  @@index([personaAId])
  @@index([personaBId])
  @@index([compatibilityScore])

  // ── auto-injected back-relations ──
  match  Match[]
}

/// =========================================================
/// SEARCH INDEX DOCUMENTS
/// =========================================================

model SearchDocument {
  id                              String                        @id @default(uuid())

  entityType                      String

  entityId                        String

  searchableText                  String

  language                        String?

  searchTokens                    Json?

  rankingSignals                  Json?

  visibilityRules                 Json?

  indexedAt                       DateTime                      @default(now())

  updatedAt                       DateTime                      @updatedAt

  @@unique([entityType, entityId])

  @@index([entityType])
  @@index([indexedAt])
}

/// =========================================================
/// MODEL REGISTRY
/// =========================================================

model MLModelRegistry {
  id                              String                        @id @default(uuid())

  modelKey                        String                        @unique

  modelName                       String

  modelType                       String

  version                         String

  status                          MLModelStatus                @default(TRAINING)

  accuracyMetric                  Float?

  precisionMetric                 Float?

  recallMetric                    Float?

  deployedAt                      DateTime?

  deprecatedAt                    DateTime?

  trainingDatasetVersion          String?

  metadata                        Json?

  createdAt                       DateTime                      @default(now())
  updatedAt                       DateTime                      @updatedAt

  @@index([modelType])
  @@index([status])
}

/// =========================================================
/// AI MODERATION SIGNALS
/// =========================================================

model AiModerationSignal {
  id                              String                        @id @default(uuid())

  entityType                      String

  entityId                        String

  modelVersion                    String

  toxicityScore                   Float?

  spamScore                       Float?

  fraudScore                      Float?

  nsfwScore                       Float?

  violenceScore                   Float?

  confidenceScore                 Float?

  moderationDecision              String?

  reviewedByHuman                 Boolean                       @default(false)

  reviewedAt                      DateTime?

  createdAt                       DateTime                      @default(now())

  metadata                        Json?

  @@index([entityType])
  @@index([entityId])
  @@index([moderationDecision])
  @@index([createdAt])
}

/// =========================================================
/// PERSONALIZATION PROFILES
/// =========================================================

model PersonalizationProfile {
  id                              String                        @id @default(uuid())

  personaId                       String                        @unique

  affinityScores                  Json?

  interactionPatterns             Json?

  activityWindows                 Json?

  communicationPreferences        Json?

  behavioralTraits                Json?

  updatedAt                       DateTime                      @updatedAt

  /// ---------- Relations ----------
  persona                         Persona                       @relation(fields: [personaId], references: [id])

  @@index([updatedAt])
}

/// =========================================================
/// PARA_PAIR ENTERPRISE ANALYTICS & OBSERVABILITY MODULE
/// Module: Analytics / Telemetry / BI / Monitoring / Events
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum AnalyticsEventType {
  AUTH
  MATCHING
  MESSAGE
  PAYMENT
  SUBSCRIPTION
  PROFILE
  LISTING
  MODERATION
  SYSTEM
  SECURITY
}

enum AnalyticsAggregationPeriod {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

enum ExperimentAssignmentStatus {
  ACTIVE
  COMPLETED
  REMOVED
}

enum MetricSeverity {
  INFO
  WARNING
  CRITICAL
}

/// =========================================================
/// RAW EVENT STREAM
/// =========================================================

model AnalyticsEvent {
  id                              String                          @id @default(uuid())

  workspaceId                     String?
  userId                          String?
  personaId                       String?

  eventType                       AnalyticsEventType

  eventName                       String

  eventVersion                    String?

  sessionId                       String?

  ipAddress                       String?

  userAgent                       String?

  country                         String?
  region                          String?
  city                            String?

  sourcePlatform                  String?

  correlationId                   String?

  properties                      Json?

  occurredAt                      DateTime                        @default(now())

  /// ---------- Relations ----------
  workspace                       Workspace?                      @relation(fields: [workspaceId], references: [id])

  user                            User?                           @relation(fields: [userId], references: [id])

  persona                         Persona?                        @relation(fields: [personaId], references: [id])

  @@index([workspaceId])
  @@index([userId])
  @@index([personaId])
  @@index([eventType])
  @@index([eventName])
  @@index([occurredAt])
}

/// =========================================================
/// USER SESSIONS
/// =========================================================

model AnalyticsSession {
  id                              String                          @id @default(uuid())

  userId                          String?
  personaId                       String?

  sessionKey                      String                          @unique

  ipAddress                       String?

  userAgent                       String?

  deviceType                      String?

  browser                         String?

  operatingSystem                 String?

  country                         String?
  region                          String?
  city                            String?

  startedAt                       DateTime                        @default(now())

  endedAt                         DateTime?

  durationSeconds                 Int?

  bounce                          Boolean                         @default(false)

  metadata                        Json?

  /// ---------- Relations ----------
  user                            User?                           @relation(fields: [userId], references: [id])

  persona                         Persona?                        @relation(fields: [personaId], references: [id])

  @@index([userId])
  @@index([personaId])
  @@index([startedAt])
}

/// =========================================================
/// FEATURE FLAGS
/// =========================================================

model FeatureFlag {
  id                              String                          @id @default(uuid())

  flagKey                         String                          @unique

  name                            String

  description                     String?

  enabled                         Boolean                         @default(false)

  rolloutPercentage               Float                           @default(0)

  targetingRules                  Json?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt

  assignments                     FeatureFlagAssignment[]         @relation(fields: [flagId], references: [id])

  @@index([enabled])
}

/// =========================================================
/// FEATURE FLAG ASSIGNMENTS
/// =========================================================

model FeatureFlagAssignment {
  id                              String                          @id @default(uuid())

  featureFlagId                   String

  userId                          String?
  workspaceId                     String?
  personaId                       String?

  assignedVariant                 String?

  status                          ExperimentAssignmentStatus      @default(ACTIVE)

  assignedAt                      DateTime                        @default(now())

  metadata                        Json?

  /// ---------- Relations ----------
  featureFlag                     FeatureFlag                     @relation(fields: [featureFlagId], references: [id])

  user                            User?                           @relation(fields: [userId], references: [id])

  workspace                       Workspace?                      @relation(fields: [workspaceId], references: [id])

  persona                         Persona?                        @relation(fields: [personaId], references: [id])

  @@index([featureFlagId])
  @@index([userId])
  @@index([workspaceId])
  @@index([personaId])
}

/// =========================================================
/// PRODUCT METRICS
/// =========================================================

model ProductMetricSnapshot {
  id                              String                          @id @default(uuid())

  metricKey                       String

  aggregationPeriod               AnalyticsAggregationPeriod

  metricDate                      DateTime

  metricValue                     Float

  dimensions                      Json?

  metadata                        Json?

  calculatedAt                    DateTime                        @default(now())

  @@unique([metricKey, aggregationPeriod, metricDate])

  @@index([metricKey])
  @@index([metricDate])
}

/// =========================================================
/// SEARCH ANALYTICS
/// =========================================================

model SearchAnalytics {
  id                              String                          @id @default(uuid())

  personaId                       String?

  searchQuery                     String

  filtersPayload                  Json?

  resultCount                     Int?

  clickedResultId                 String?

  searchDurationMs                Int?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  persona                         Persona?                        @relation(fields: [personaId], references: [id])

  @@index([personaId])
  @@index([createdAt])
}

/// =========================================================
/// SYSTEM METRICS
/// =========================================================

model SystemMetric {
  id                              String                          @id @default(uuid())

  metricKey                       String

  metricValue                     Float

  severity                        MetricSeverity                 @default(INFO)

  sourceService                   String?

  sourceRegion                    String?

  metadata                        Json?

  measuredAt                      DateTime                        @default(now())

  @@index([metricKey])
  @@index([severity])
  @@index([measuredAt])
}

/// =========================================================
/// ERROR TRACKING
/// =========================================================

model ErrorLog {
  id                              String                          @id @default(uuid())

  serviceName                     String

  environment                     String

  errorType                       String

  errorMessage                    String

  stackTrace                      String?

  requestId                       String?

  correlationId                   String?

  endpoint                        String?

  httpMethod                      String?

  responseStatus                  Int?

  userId                          String?
  workspaceId                     String?

  metadata                        Json?

  occurredAt                      DateTime                        @default(now())

  /// ---------- Relations ----------
  user                            User?                           @relation(fields: [userId], references: [id])

  workspace                       Workspace?                      @relation(fields: [workspaceId], references: [id])

  @@index([serviceName])
  @@index([errorType])
  @@index([occurredAt])
}

/// =========================================================
/// AUDIT EXPORTS
/// =========================================================

model AuditExportJob {
  id                              String                          @id @default(uuid())

  requestedByUserId               String

  exportType                      String

  exportLocation                  String?

  exportFormat                    String?

  status                          String

  startedAt                       DateTime?

  completedAt                     DateTime?

  failedAt                        DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  requestedByUser                 User                            @relation(fields: [requestedByUserId], references: [id])

  @@index([requestedByUserId])
  @@index([status])
  @@index([createdAt])
}

///////////////////////////////////////////////////////////////
// DATA WAREHOUSE + CQRS MODULE
// Event sourcing projection layer for analytics + BI
///////////////////////////////////////////////////////////////

enum EventStreamType {
  USER
  SYSTEM
  PAYMENT
  FRAUD
  SEARCH
  MESSAGING
}

enum ProjectionStatus {
  ACTIVE
  REBUILDING
  FAILED
}

model EventStream {
  id              String @id @default(cuid())

  streamType      EventStreamType

  aggregateId     String

  eventType       String

  version         Int

  payload         Json

  createdAt       DateTime @default(now())

  @@index([streamType, aggregateId])
  @@index([createdAt])
}

model EventSnapshot {
  id              String @id @default(cuid())

  aggregateId     String

  streamType      EventStreamType

  snapshot        Json

  version         Int

  createdAt       DateTime @default(now())

  @@index([aggregateId])
}

model CQRSProjection {
  id              String @id @default(cuid())

  name            String

  sourceStream    EventStreamType

  status          ProjectionStatus @default(ACTIVE)

  lastProcessedVersion Int @default(0)

  updatedAt       DateTime @updatedAt

  @@index([name])
}

model AnalyticsFactTable {
  id              String @id @default(cuid())

  eventType       String

  userId          String?

  dimensions      Json

  measures        Json

  eventTime       DateTime

  createdAt       DateTime @default(now())

  @@index([eventType, eventTime])
  @@index([userId])
}

model DataPipelineJob {
  id              String @id @default(cuid())

  name            String

  status          String

  inputSource     String

  outputTarget    String

  lastRunAt       DateTime?

  nextRunAt       DateTime?

  config          Json?

  createdAt       DateTime @default(now())

  @@index([status])
}

/// =========================================================
/// PARA_PAIR ENTERPRISE DISASTER RECOVERY & ARCHIVAL MODULE
/// Module: DR / Archival / Retention / Recovery / Cold Storage
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum ArchiveStatus {
  PENDING
  ARCHIVED
  RESTORED
  PURGED
}

enum RecoveryJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum BackupType {
  FULL
  INCREMENTAL
  DIFFERENTIAL
}

enum StorageTier {
  HOT
  WARM
  COLD
  GLACIER
}

enum RecoveryPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum DataClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

/// =========================================================
/// ARCHIVE REGISTRY
/// =========================================================

model ArchiveRecord {
  id                              String                          @id @default(uuid())

  entityType                      String

  entityId                        String

  archiveStatus                   ArchiveStatus                  @default(PENDING)

  dataClassification              DataClassification             @default(CONFIDENTIAL)

  archiveReason                   String?

  archivedPayload                 Json

  archiveChecksum                 String?

  storageTier                     StorageTier                    @default(COLD)

  storageLocation                 String

  retentionUntil                  DateTime?

  archivedAt                      DateTime?

  restoredAt                      DateTime?

  purgedAt                        DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  @@unique([entityType, entityId])

  @@index([archiveStatus])
  @@index([storageTier])
  @@index([retentionUntil])
  @@index([createdAt])
}

/// =========================================================
/// DATABASE BACKUPS
/// =========================================================

model DatabaseBackup {
  id                              String                          @id @default(uuid())

  backupKey                       String                          @unique

  backupType                      BackupType

  environment                     DeploymentEnvironment

  storageTier                     StorageTier                    @default(GLACIER)

  encrypted                       Boolean                         @default(true)

  encryptionVersion               String?

  storageProvider                 String

  storageLocation                 String

  checksum                        String?

  fileSizeBytes                   BigInt?

  startedAt                       DateTime

  completedAt                     DateTime?

  expiresAt                       DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  recoveryJobs                    RecoveryJob[]

  @@index([backupType])
  @@index([environment])
  @@index([startedAt])
}

/// =========================================================
/// RECOVERY JOBS
/// =========================================================

model RecoveryJob {
  id                              String                          @id @default(uuid())

  databaseBackupId                String

  requestedByUserId               String?

  status                          RecoveryJobStatus             @default(PENDING)

  priority                        RecoveryPriority              @default(NORMAL)

  targetEnvironment               DeploymentEnvironment

  restorePoint                    DateTime?

  startedAt                       DateTime?

  completedAt                     DateTime?

  failedAt                        DateTime?

  failureReason                   String?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  databaseBackup                  DatabaseBackup                 @relation(fields: [databaseBackupId], references: [id])

  requestedByUser                 User?                           @relation(fields: [requestedByUserId], references: [id])

  @@index([databaseBackupId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

/// =========================================================
/// DATA RETENTION EXECUTIONS
/// =========================================================

model RetentionExecution {
  id                              String                          @id @default(uuid())

  retentionPolicyId               String

  entityType                      String

  processedRecords                Int                             @default(0)

  archivedRecords                 Int                             @default(0)

  purgedRecords                   Int                             @default(0)

  failedRecords                   Int                             @default(0)

  startedAt                       DateTime                        @default(now())

  completedAt                     DateTime?

  failureReason                   String?

  metadata                        Json?

  /// ---------- Relations ----------
  retentionPolicy                 DataRetentionPolicy            @relation(fields: [retentionPolicyId], references: [id])

  @@index([retentionPolicyId])
  @@index([startedAt])
}

/// =========================================================
/// CROSS-REGION REPLICATION
/// =========================================================

model CrossRegionReplication {
  id                              String                          @id @default(uuid())

  sourceRegion                    String

  targetRegion                    String

  replicationLagMs                Int?

  replicationHealthy              Boolean                         @default(true)

  lastSyncedAt                    DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt

  @@unique([sourceRegion, targetRegion])

  @@index([replicationHealthy])
  @@index([lastSyncedAt])
}

/// =========================================================
/// BUSINESS CONTINUITY PLANS
/// =========================================================

model BusinessContinuityPlan {
  id                              String                          @id @default(uuid())

  planKey                         String                          @unique

  planName                        String

  description                     String?

  rtoMinutes                      Int

  rpoMinutes                      Int

  escalationMatrix                Json?

  communicationPlan               Json?

  recoveryProcedures              Json?

  testFrequencyDays               Int?

  lastTestedAt                    DateTime?

  nextTestAt                      DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt

  @@index([nextTestAt])

  // ── auto-injected back-relations ──
  disasterRecoveryTest  DisasterRecoveryTest[]
}

/// =========================================================
/// DISASTER RECOVERY TESTS
/// =========================================================

model DisasterRecoveryTest {
  id                              String                          @id @default(uuid())

  businessContinuityPlanId        String

  executedByUserId                String?

  testScenario                    String

  success                         Boolean                         @default(true)

  findings                        String?

  remediationItems                Json?

  startedAt                       DateTime

  completedAt                     DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  businessContinuityPlan          BusinessContinuityPlan          @relation(fields: [businessContinuityPlanId], references: [id])

  executedByUser                  User?                           @relation(fields: [executedByUserId], references: [id])

  @@index([businessContinuityPlanId])
  @@index([success])
  @@index([startedAt])
}

/// =========================================================
/// FAILOVER EVENTS
/// =========================================================

model FailoverEvent {
  id                              String                          @id @default(uuid())

  sourceRegion                    String

  targetRegion                    String

  triggerReason                   String

  initiatedBy                     String?

  successful                      Boolean                         @default(true)

  downtimeSeconds                 Int?

  startedAt                       DateTime

  completedAt                     DateTime?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  @@index([sourceRegion])
  @@index([targetRegion])
  @@index([startedAt])
}

/// =========================================================
/// EVIDENCE VAULT
/// =========================================================

model ComplianceEvidenceVault {
  id                              String                          @id @default(uuid())

  evidenceKey                     String                          @unique

  evidenceType                    String

  storageLocation                 String

  checksum                        String

  collectedAt                     DateTime                        @default(now())

  expiresAt                       DateTime?

  legalHold                       Boolean                         @default(false)

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  @@index([evidenceType])
  @@index([legalHold])
  @@index([expiresAt])
}

/// =========================================================
/// PARA_PAIR ENTERPRISE EVENT SOURCING & WORKFLOW MODULE
/// Module: Event Bus / Domain Events / Saga / Workflow Engine
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum DomainEventStatus {
  PENDING
  PUBLISHED
  FAILED
  ARCHIVED
}

enum WorkflowExecutionStatus {
  PENDING
  RUNNING
  WAITING
  COMPLETED
  FAILED
  CANCELED
}

enum WorkflowStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

enum SagaExecutionStatus {
  STARTED
  PROCESSING
  COMPENSATING
  COMPLETED
  FAILED
}

enum OutboxStatus {
  PENDING
  DISPATCHED
  FAILED
}

/// =========================================================
/// DOMAIN EVENTS
/// =========================================================

model DomainEvent {
  id                              String                          @id @default(uuid())

  aggregateType                   String

  aggregateId                     String

  eventType                       String

  eventVersion                    String

  eventStatus                     DomainEventStatus             @default(PENDING)

  correlationId                   String?

  causationId                     String?

  actorUserId                     String?

  workspaceId                     String?

  payload                         Json

  metadata                        Json?

  occurredAt                      DateTime                        @default(now())

  publishedAt                     DateTime?

  archivedAt                      DateTime?

  /// ---------- Relations ----------
  actorUser                       User?                           @relation(fields: [actorUserId], references: [id])

  workspace                       Workspace?                      @relation(fields: [workspaceId], references: [id])

  outboxEntries                   EventOutbox[]

  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([eventStatus])
  @@index([occurredAt])
  @@index([correlationId])
}

/// =========================================================
/// EVENT OUTBOX
/// =========================================================

model EventOutbox {
  id                              String                          @id @default(uuid())

  domainEventId                   String

  destination                     String

  topic                           String

  payload                         Json

  status                          OutboxStatus                  @default(PENDING)

  retryCount                      Int                             @default(0)

  nextRetryAt                     DateTime?

  dispatchedAt                    DateTime?

  failedAt                        DateTime?

  lastError                       String?

  metadata                        Json?

  createdAt                       DateTime                        @default(now())

  /// ---------- Relations ----------
  domainEvent                     DomainEvent                     @relation(fields: [domainEventId], references: [id])

  @@index([domainEventId])
  @@index([status])
  @@index([nextRetryAt])
}

/// =========================================================
/// WORKFLOW DEFINITIONS
/// =========================================================

model WorkflowDefinition {
  id                              String                          @id @default(uuid())

  workflowKey                     String                          @unique

  workflowName                    String

  workflowVersion                 String

  description                     String?

  definitionPayload               Json

  isActive                        Boolean                         @default(true)

  metadata                        Json?

  createdAt                       DateTime                        @default(now())
  updatedAt                       DateTime                        @updatedAt

  executions                      WorkflowExecution[]

  @@index([workflowKey])
  @@index([isActive])
}

/// =========================================================
/// WORKFLOW EXECUTIONS
/// =========================================================

model WorkflowExecution {
  id                              String                          @id @default(uuid())

  workflowDefinitionId            String

  status                          WorkflowExecutionStatus       @default(PENDING)

  startedByUserId                 String?

  workspaceId                     String?

  correlationId                   String?

  inputPayload                    Json?

  outputPayload                   Json?

  failureReason                   String?

  startedAt                       DateTime                        @default(now())

  completedAt                     DateTime?

  canceledAt                      DateTime?

  metadata                        Json?

  /// ---------- Relations ----------
  workflowDefinition              WorkflowDefinition              @relation(fields: [workflowDefinitionId], references: [id])

  startedByUser                   User?                           @relation(fields: [startedByUserId], references: [id])

  workspace                       Workspace?                      @relation(fields: [workspaceId], references: [id])

  steps                           WorkflowStepExecution[]

