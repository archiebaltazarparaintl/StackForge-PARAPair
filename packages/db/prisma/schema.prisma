///////////////////////////////////////////////////////////////
// OBSERVABILITY + FORENSICS MODULE
// Distributed tracing + audit-grade forensic reconstruction
///////////////////////////////////////////////////////////////

enum LogSeverity {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}

enum TraceSpanType {
  HTTP
  DB
  CACHE
  QUEUE
  AUTH
  INTERNAL
  EXTERNAL_API
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ForensicEventType {
  USER_ACTION
  SYSTEM_EVENT
  SECURITY_EVENT
  FRAUD_EVENT
  PAYMENT_EVENT
}

model DistributedTrace {
  id              String @id @default(cuid())

  traceId         String @unique
  userId          String?

  rootSpanId      String?

  latencyMs       Int

  success         Boolean @default(true)

  createdAt       DateTime @default(now())

  spans           TraceSpan[]

  @@index([traceId])
  @@index([userId])
}

model TraceSpan {
  id              String @id @default(cuid())

  traceId         String
  parentSpanId    String?

  spanType        TraceSpanType

  operationName   String

  startTime       DateTime
  endTime         DateTime?

  durationMs      Int?

  metadata        Json?

  trace           DistributedTrace @relation(fields: [traceId], references: [traceId])

  @@index([traceId])
  @@index([spanType])
}

model LogEvent {
  id              String @id @default(cuid())

  serviceName     String

  severity        LogSeverity

  message         String

  userId          String?

  traceId         String?

  metadata        Json?

  createdAt       DateTime @default(now())

  @@index([serviceName, severity])
  @@index([traceId])
  @@index([createdAt])
}

model IncidentReport {
  id              String @id @default(cuid())

  title           String

  description     String?

  severity        IncidentSeverity

  isResolved      Boolean @default(false)

  assignedTo      String?

  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  forensicEvents  ForensicEvent[]

  @@index([severity])
  @@index([isResolved])
}

model ForensicEvent {
  id              String @id @default(cuid())

  eventType       ForensicEventType

  userId          String?

  traceId         String?

  payload         Json

  createdAt       DateTime @default(now())

  incidentReport  IncidentReport?  @relation(fields: [incidentReportId], references: [id])
  incidentReportId  String?

  

  @@index([eventType])
  @@index([traceId])
  @@index([userId])
}

/// =========================================================
/// PARA_PAIR ENTERPRISE PAYMENTS & BILLING MODULE
/// Module: Billing / Subscriptions / Invoices / Tax / Revenue
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum BillingProvider {
  STRIPE
  PAYPAL
  XENDIT
  PAYMONGO
  ADYEN

  GCASH
  MAYA

  PESONET
  INSTAPAY

  BANK_TRANSFER

  WISE
  MANUAL
}


enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  CHARGEBACK
}

enum PaymentMethodType {
  CARD
  BANK_TRANSFER

  GCASH
  MAYA

  PESONET
  INSTAPAY

  EWALLET

  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TaxType {
  VAT
  SALES_TAX
  WITHHOLDING
}

/// =========================================================
/// BILLING CUSTOMERS
/// =========================================================

model BillingCustomer {
  id                              String                      @id @default(uuid())

  workspaceId                     String                      @unique

  provider                        BillingProvider

  providerCustomerId              String

  email                           String

  billingName                     String?

  country                         String?

  taxId                           String?

  isTaxExempt                     Boolean                     @default(false)

  metadata                        Json?

  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt

  /// ---------- Relations ----------
  workspace                       Workspace                   @relation(fields: [workspaceId], references: [id])

  paymentMethods                  PaymentMethod[]
  subscriptions                   BillingSubscription[]
  invoices                        Invoice[]

  @@unique([provider, providerCustomerId])

  @@index([workspaceId])
  @@index([provider])
}

/// =========================================================
/// PAYMENT METHODS
/// =========================================================

model PaymentMethod {
  id                              String                      @id @default(uuid())

  billingCustomerId               String

  type                            PaymentMethodType

  provider                        BillingProvider

  providerPaymentMethodId         String

  brand                           String?
  last4                           String?

  expiryMonth                     Int?
  expiryYear                      Int?

  isDefault                       Boolean                     @default(false)

  fingerprint                     String?

  metadata                        Json?

  createdAt                       DateTime                    @default(now())

  /// ---------- Relations ----------
  billingCustomer                 BillingCustomer             @relation(fields: [billingCustomerId], references: [id])

  @@unique([provider, providerPaymentMethodId])

  @@index([billingCustomerId])
  @@index([isDefault])

  // ── auto-injected back-relations ──
  payment  Payment[]
}

/// =========================================================
/// SUBSCRIPTION PLANS
/// =========================================================

model SubscriptionPlan {
  id                              String                      @id @default(uuid())

  planKey                         String                      @unique

  name                            String

  description                     String?

  billingCycle                    BillingCycle

  amount                          Decimal                     @db.Decimal(12, 2)

  currency                        String

  trialDays                       Int?

  isActive                        Boolean                     @default(true)

  featureFlags                    Json?

  limitsPayload                   Json?

  metadata                        Json?

  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt

  subscriptions                   BillingSubscription[]

  @@index([billingCycle])
  @@index([isActive])
}

/// =========================================================
/// BILLING SUBSCRIPTIONS
/// =========================================================

model BillingSubscription {
  id                              String                      @id @default(uuid())

  billingCustomerId               String

  subscriptionPlanId              String

  provider                        BillingProvider

  providerSubscriptionId          String

  status                          SubscriptionStatus          @default(TRIALING)

  startedAt                       DateTime

  currentPeriodStart              DateTime
  currentPeriodEnd                DateTime

  canceledAt                      DateTime?
  expiresAt                       DateTime?

  autoRenew                       Boolean                     @default(true)

  seats                           Int                         @default(1)

  metadata                        Json?

  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt

  /// ---------- Relations ----------
  billingCustomer                 BillingCustomer             @relation(fields: [billingCustomerId], references: [id])

  subscriptionPlan                SubscriptionPlan            @relation(fields: [subscriptionPlanId], references: [id])

  invoices                        Invoice[]

  @@unique([provider, providerSubscriptionId])

  @@index([billingCustomerId])
  @@index([subscriptionPlanId])
  @@index([status])
  @@index([currentPeriodEnd])
}

/// =========================================================
/// INVOICES
/// =========================================================

model Invoice {
  id                              String                      @id @default(uuid())

  billingCustomerId               String

  billingSubscriptionId           String?

  invoiceNumber                   String                      @unique

  status                          InvoiceStatus               @default(DRAFT)

  currency                        String

  subtotalAmount                  Decimal                     @db.Decimal(12, 2)
  taxAmount                       Decimal                     @db.Decimal(12, 2)
  totalAmount                     Decimal                     @db.Decimal(12, 2)

  issuedAt                        DateTime                    @default(now())

  dueAt                           DateTime?

  paidAt                          DateTime?

  voidedAt                        DateTime?

  refundedAt                      DateTime?

  metadata                        Json?

  createdAt                       DateTime                    @default(now())

  /// ---------- Relations ----------
  billingCustomer                 BillingCustomer             @relation(fields: [billingCustomerId], references: [id])

  billingSubscription             BillingSubscription?        @relation(fields: [billingSubscriptionId], references: [id])

  lineItems                       InvoiceLineItem[]

  payments                        Payment[]

  taxes                           InvoiceTax[]

  @@index([billingCustomerId])
  @@index([billingSubscriptionId])
  @@index([status])
  @@index([issuedAt])
}

/// =========================================================
/// INVOICE LINE ITEMS
/// =========================================================

model InvoiceLineItem {
  id                              String                      @id @default(uuid())

  invoiceId                       String

  description                     String

  quantity                        Int                         @default(1)

  unitPrice                       Decimal                     @db.Decimal(12, 2)

  totalAmount                     Decimal                     @db.Decimal(12, 2)

  metadata                        Json?

  createdAt                       DateTime                    @default(now())

  /// ---------- Relations ----------
  invoice                         Invoice                     @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

/// =========================================================
/// INVOICE TAXES
/// =========================================================

model InvoiceTax {
  id                              String                      @id @default(uuid())

  invoiceId                       String

  taxType                         TaxType

  taxRate                         Decimal                     @db.Decimal(5, 2)

  taxAmount                       Decimal                     @db.Decimal(12, 2)

  jurisdiction                    String?

  metadata                        Json?

  createdAt                       DateTime                    @default(now())

  /// ---------- Relations ----------
  invoice                         Invoice                     @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([taxType])
}

/// =========================================================
/// PAYMENTS
/// =========================================================

model Payment {
  id                              String                      @id @default(uuid())

  invoiceId                       String

  paymentMethodId                 String?

  provider                        BillingProvider

  providerPaymentId               String

  status                          PaymentStatus               @default(PENDING)

  amount                          Decimal                     @db.Decimal(12, 2)

  currency                        String

  processedAt                     DateTime?

  failedAt                        DateTime?

  refundedAt                      DateTime?

  failureReason                   String?

  metadata                        Json?

  createdAt                       DateTime                    @default(now())

  /// ---------- Relations ----------
  invoice                         Invoice                     @relation(fields: [invoiceId], references: [id])

  paymentMethod                   PaymentMethod?              @relation(fields: [paymentMethodId], references: [id])

  refunds                         Refund[]

  @@unique([provider, providerPaymentId])

  @@index([invoiceId])
  @@index([paymentMethodId])
  @@index([status])
  @@index([processedAt])
}

model BankAccount {
  id                              String                      @id @default(uuid())

  workspaceId                     String

  accountName                     String

  bankName                        String

  accountNumberEncrypted          String

  accountNumberLast4              String

  routingNumberEncrypted          String?

  swiftCode                       String?

  iban                            String?

  country                         String

  currency                        String

  isVerified                      Boolean                     @default(false)

  verificationMethod              String?

  verifiedAt                      DateTime?

  isDefault                       Boolean                     @default(false)

  metadata                        Json?

  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt

  /// ---------- Relations ----------
  workspace                       Workspace                   @relation(fields: [workspaceId], references: [id])

  payouts                         Payout[]

  @@index([workspaceId])
  @@index([isDefault])
}

model WalletAccount {
  id                              String                      @id @default(uuid())

  workspaceId                     String

  provider                        PaymentMethodType

  mobileNumberEncrypted           String

  mobileNumberLast4               String

  accountName                     String?

  isVerified                      Boolean                     @default(false)

  verifiedAt                      DateTime?

  isDefault                       Boolean                     @default(false)

  metadata                        Json?

  createdAt                       DateTime                    @default(now())

  /// ---------- Relations ----------
  workspace                       Workspace                   @relation(fields: [workspaceId], references: [id])

  payouts                         Payout[]

  @@index([workspaceId])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
  CANCELED
}

model Payout {
  id                              String                      @id @default(uuid())

  workspaceId                     String

  bankAccountId                   String?
  walletAccountId                 String?

  provider                        BillingProvider

  amount                          Decimal                     @db.Decimal(12, 2)

  currency                        String

  status                          PayoutStatus                @default(PENDING)

  externalReferenceId             String?

  description                     String?

  processedAt                     DateTime?

  failedAt                        DateTime?

  failureReason                   String?

  metadata                        Json?

  createdAt                       DateTime                    @default(now())
  updatedAt                       DateTime                    @updatedAt

  /// ---------- Relations ----------
  workspace                       Workspace                   @relation(fields: [workspaceId], references: [id])

  bankAccount                     BankAccount?                @relation(fields: [bankAccountId], references: [id])

  walletAccount                   WalletAccount?              @relation(fields: [walletAccountId], references: [id])

  @@index([workspaceId])
  @@index([status])
  @@index([processedAt])
}

model FinancialRiskEvent {
  id                              String                      @id @default(uuid())

  workspaceId                     String?

  paymentId                       String?

  payoutId                        String?

  riskType                        String

  riskScore                       Float

  investigationStatus             String?

  notes                           String?

  createdAt                       DateTime                    @default(now())

  @@index([workspaceId])
  @@index([riskScore])
}


/// =========================================================
/// REFUNDS
/// =========================================================

model Refund {
  id                              String                      @id @default(uuid())

  paymentId                       String

  providerRefundId                String?

  status                          RefundStatus                @default(PENDING)

  amount                          Decimal                     @db.Decimal(12, 2)

  currency                        String

  reason                          String?

  processedAt                     DateTime?

  metadata                        Json?

  createdAt                       DateTime                    @default(now())

  /// ---------- Relations ----------
  payment                         Payment                     @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([status])
}

/// =========================================================
/// WEBHOOK EVENTS
/// =========================================================

model BillingWebhookEvent {
  id                              String                      @id @default(uuid())

  provider                        BillingProvider

  eventId                         String

  eventType                       String

  payload                         Json

  processed                       Boolean                     @default(false)

  processedAt                     DateTime?

  failedAt                        DateTime?

  failureReason                   String?

  createdAt                       DateTime                    @default(now())

  @@unique([provider, eventId])

  @@index([provider])
  @@index([eventType])
  @@index([processed])
}

/// =========================================================
/// PARA_PAIR ENTERPRISE PERSONA & MARKETPLACE MODULE
/// Module: Personas / Marketplace Identity / Skills / Discovery
/// Classification: Enterprise-Grade
/// =========================================================

/// =========================================================
/// ENUMS
/// =========================================================

enum PersonaType {
  INDIVIDUAL
  BUSINESS
  AGENCY
  RECRUITER
  CREATOR
  FREELANCER
}

enum PersonaStatus {
  DRAFT
  ACTIVE
  PAUSED
  BANNED
  ARCHIVED
}

enum MarketplaceMode {
  WORK
  HIRE
  SELL
  BUY
}

enum VerificationBadge {
  NONE
  VERIFIED
  PREMIUM
  ENTERPRISE
  GOVERNMENT_VERIFIED
}

enum AvailabilityStatus {
  AVAILABLE
  LIMITED
  UNAVAILABLE
}

enum VisibilityLevel {
  PUBLIC
  PLATFORM_ONLY
  PRIVATE
}

enum ListingType {
  SERVICE
  JOB
  PRODUCT
  PROJECT
  PARTNERSHIP
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  FILLED
  EXPIRED
  REMOVED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
}

/// =========================================================
/// PERSONA
/// =========================================================

model Persona {
  id                              String                  @id @default(uuid())

  workspaceId                     String

  /// ---------- Identity ----------
  type                            PersonaType
  status                          PersonaStatus           @default(DRAFT)

  displayName                     String
  slug                            String                  @unique

  headline                        String?
  bio                             String?

  /// ---------- Marketplace ----------
  marketplaceMode                 MarketplaceMode

  /// ---------- Trust ----------
  trustScore                      Float                   @default(0)

  verificationBadge               VerificationBadge       @default(NONE)

  verifiedAt                      DateTime?

  /// ---------- Visibility ----------
  visibility                      VisibilityLevel         @default(PUBLIC)

  isDiscoverable                  Boolean                 @default(true)

  /// ---------- Availability ----------
  availabilityStatus              AvailabilityStatus      @default(AVAILABLE)

  responseRate                    Float                   @default(0)
  responseTimeMinutes             Int?

  /// ---------- Metrics ----------
  totalMatches                    Int                     @default(0)
  totalProjects                   Int                     @default(0)
  totalReviews                    Int                     @default(0)

  averageRating                   Float                   @default(0)

  /// ---------- Search ----------
  searchVector                    Unsupported("tsvector")?

  /// ---------- Metadata ----------
  metadata                        Json?

  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  deletedAt                       DateTime?

  /// ---------- Relations ----------
  workspace                       Workspace               @relation(fields: [workspaceId], references: [id])

  profile                         PersonaProfile?

  skills                          PersonaSkill[]
  interests                       PersonaInterest[]
  intents                         PersonaIntent[]

  media                           PersonaMedia[]

  listings                        Listing[]

  reviewsReceived                 PersonaReview[]         @relation("ReviewTarget")
  reviewsWritten                  PersonaReview[]         @relation("ReviewAuthor")

  bookmarksAsSource               PersonaBookmark[]       @relation("BookmarkSource")
  bookmarksAsTarget               PersonaBookmark[]       @relation("BookmarkTarget")

  blocksGiven                     PersonaBlock[]          @relation("PersonaBlocker")
  blocksReceived                  PersonaBlock[]          @relation("PersonaBlocked")

  reportsReceived                 PersonaReport[]         @relation("PersonaReportTarget")
  reportsMade                     PersonaReport[]         @relation("PersonaReporter")

  @@index([workspaceId])
  @@index([type])
  @@index([status])
  @@index([marketplaceMode])
  @@index([verificationBadge])
  @@index([trustScore])
  @@index([isDiscoverable])
  @@index([deletedAt])

  // ── auto-injected back-relations ──
  recommendationCandidate_RecommendationOwner  RecommendationCandidate[]  @relation("RecommendationOwner")
  recommendationCandidate_RecommendationTargetPersona  RecommendationCandidate[]  @relation("RecommendationTargetPersona")
  recommendationFeedback  RecommendationFeedback[]
  matchScore_MatchScorePersonaA  MatchScore[]  @relation("MatchScorePersonaA")
  matchScore_MatchScorePersonaB  MatchScore[]  @relation("MatchScorePersonaB")
  personalizationProfile  PersonalizationProfile[]
  analyticsEvent  AnalyticsEvent[]
  analyticsSession  AnalyticsSession[]
  featureFlagAssignment  FeatureFlagAssignment[]
  searchAnalytics  SearchAnalytics[]
  feedGenerationJob  FeedGenerationJob[]
  feedSnapshot  FeedSnapshot[]
  feedCard_FeedCardSource  FeedCard[]  @relation("FeedCardSource")
  feedCard_FeedCardTarget  FeedCard[]  @relation("FeedCardTarget")
  swipeEvent_SwipeSource  SwipeEvent[]  @relation("SwipeSource")
  swipeEvent_SwipeTarget  SwipeEvent[]  @relation("SwipeTarget")
  match_MatchPersonaA  Match[]  @relation("MatchPersonaA")
  match_MatchPersonaB  Match[]  @relation("MatchPersonaB")
  matchInteraction  MatchInteraction[]
  personaEmbedding  PersonaEmbedding[]
  discoveryAnalytics  DiscoveryAnalytics[]
  conversationParticipant  ConversationParticipant[]
  message  Message[]
  messageReceipt  MessageReceipt[]
  messageReaction  MessageReaction[]
  presence  Presence[]
  typingIndicator  TypingIndicator[]
  webSocketConnection  WebSocketConnection[]
  pushNotificationDevice  PushNotificationDevice[]
  notificationQueue  NotificationQueue[]
  listingApplication  ListingApplication[]
  listingBookmark  ListingBookmark[]
  moderationCase  ModerationCase[]
  moderationCase_ModerationReporter  ModerationCase[]  @relation("ModerationReporter")
  fraudCase  FraudCase[]
}

/// =========================================================
/// PERSONA PROFILE
/// =========================================================

model PersonaProfile {
  id                              String                  @id @default(uuid())

  personaId                       String                  @unique

  /// ---------- Professional ----------
  yearsExperience                 Int?

  hourlyRateMin                   Decimal?                @db.Decimal(12, 2)
  hourlyRateMax                   Decimal?                @db.Decimal(12, 2)

  currency                        String?

  /// ---------- Education ----------
  education                       Json?

  certifications                  Json?

  /// ---------- Social ----------
  portfolioUrl                    String?
  linkedinUrl                     String?
  githubUrl                       String?
  websiteUrl                      String?

  /// ---------- Location ----------
  country                         String?
  region                          String?
  city                            String?

  timezone                        String?

  /// ---------- Preferences ----------
  remoteOnly                      Boolean                 @default(false)

  willingToRelocate               Boolean                 @default(false)

  /// ---------- Metadata ----------
  metadata                        Json?

  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt

  /// ---------- Relations ----------
  persona                         Persona                 @relation(fields: [personaId], references: [id])

  @@index([country])
  @@index([city])
  @@index([remoteOnly])
}

/// =========================================================
/// SKILLS
/// =========================================================

model Skill {
  id                              String                  @id @default(uuid())

  name                            String                  @unique
  slug                            String                  @unique

  category                        String?

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  personas                        PersonaSkill[]

  @@index([category])
}

/// =========================================================
/// PERSONA SKILLS
/// =========================================================

model PersonaSkill {
  id                              String                  @id @default(uuid())

  personaId                       String
  skillId                         String

  proficiency                     Int?

  yearsExperience                 Int?

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  persona                         Persona                 @relation(fields: [personaId], references: [id])

  skill                           Skill                   @relation(fields: [skillId], references: [id])

  @@unique([personaId, skillId])

  @@index([personaId])
  @@index([skillId])
}

/// =========================================================
/// INTERESTS
/// =========================================================

model Interest {
  id                              String                  @id @default(uuid())

  name                            String                  @unique
  slug                            String                  @unique

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  personas                        PersonaInterest[]
}

/// =========================================================
/// PERSONA INTERESTS
/// =========================================================

model PersonaInterest {
  id                              String                  @id @default(uuid())

  personaId                       String
  interestId                      String

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  persona                         Persona                 @relation(fields: [personaId], references: [id])

  interest                        Interest                @relation(fields: [interestId], references: [id])

  @@unique([personaId, interestId])

  @@index([personaId])
  @@index([interestId])
}

/// =========================================================
/// PERSONA INTENTS
/// =========================================================

model PersonaIntent {
  id                              String                  @id @default(uuid())

  personaId                       String

  intentKey                       String

  metadata                        Json?

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  persona                         Persona                 @relation(fields: [personaId], references: [id])

  @@index([personaId])
  @@index([intentKey])
}

/// =========================================================
/// PERSONA MEDIA
/// =========================================================

model PersonaMedia {
  id                              String                  @id @default(uuid())

  personaId                       String

  storageKey                      String

  mimeType                        String

  fileSize                        Int

  checksum                        String

  isPrimary                       Boolean                 @default(false)

  altText                         String?

  moderationStatus                String?

  malwareScanStatus               String?

  metadata                        Json?

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  persona                         Persona                 @relation(fields: [personaId], references: [id])

  @@index([personaId])
  @@index([isPrimary])
}

/// =========================================================
/// LISTINGS
/// =========================================================

model Listing {
  id                              String                  @id @default(uuid())

  workspaceId                     String
  personaId                       String

  type                            ListingType
  status                          ListingStatus           @default(DRAFT)

  title                           String
  slug                            String                  @unique

  summary                         String?

  description                     String

  category                        String?

  /// ---------- Pricing ----------
  priceMin                        Decimal?                @db.Decimal(12, 2)
  priceMax                        Decimal?                @db.Decimal(12, 2)

  currency                        String?

  /// ---------- Availability ----------
  availableFrom                   DateTime?
  availableUntil                  DateTime?

  /// ---------- Visibility ----------
  visibility                      VisibilityLevel         @default(PUBLIC)

  /// ---------- Metrics ----------
  totalViews                      Int                     @default(0)
  totalApplications               Int                     @default(0)
  totalBookmarks                  Int                     @default(0)

  /// ---------- Search ----------
  searchVector                    Unsupported("tsvector")?

  /// ---------- Metadata ----------
  metadata                        Json?

  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  deletedAt                       DateTime?

  /// ---------- Relations ----------
  workspace                       Workspace               @relation(fields: [workspaceId], references: [id])

  persona                         Persona                 @relation(fields: [personaId], references: [id])

  applications                    ListingApplication[]
  bookmarks                       ListingBookmark[]

  @@index([workspaceId])
  @@index([personaId])
  @@index([type])
  @@index([status])
  @@index([visibility])
  @@index([deletedAt])

  // ── auto-injected back-relations ──
  recommendationCandidate  RecommendationCandidate[]
}

/// =========================================================
/// LISTING APPLICATIONS
/// =========================================================

model ListingApplication {
  id                              String                  @id @default(uuid())

  listingId                       String
  applicantPersonaId              String

  status                          ApplicationStatus       @default(PENDING)

  coverLetter                     String?

  proposedRate                    Decimal?                @db.Decimal(12, 2)

  metadata                        Json?

  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt

  /// ---------- Relations ----------
  listing                         Listing                 @relation(fields: [listingId], references: [id])

  applicantPersona                Persona                 @relation(fields: [applicantPersonaId], references: [id])

  @@unique([listingId, applicantPersonaId])

  @@index([listingId])
  @@index([applicantPersonaId])
  @@index([status])
}

/// =========================================================
/// BOOKMARKS
/// =========================================================

model PersonaBookmark {
  id                              String                  @id @default(uuid())

  sourcePersonaId                 String
  targetPersonaId                 String

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  sourcePersona                   Persona                 @relation("BookmarkSource", fields: [sourcePersonaId], references: [id])

  targetPersona                   Persona                 @relation("BookmarkTarget", fields: [targetPersonaId], references: [id])

  @@unique([sourcePersonaId, targetPersonaId])

  @@index([sourcePersonaId])
  @@index([targetPersonaId])
}
model ListingBookmark {
  id                              String                  @id @default(uuid())

  personaId                       String
  listingId                       String

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  persona                         Persona                 @relation(fields: [personaId], references: [id])

  listing                         Listing                 @relation(fields: [listingId], references: [id])

  @@unique([personaId, listingId])

  @@index([personaId])
  @@index([listingId])
}

/// =========================================================
/// REVIEWS
/// =========================================================

model PersonaReview {
  id                              String                  @id @default(uuid())

  authorPersonaId                 String
  targetPersonaId                 String

  rating                          Int

  title                           String?
  reviewText                      String?

  isVerifiedInteraction           Boolean                 @default(false)

  moderationStatus                String?

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  authorPersona                   Persona                 @relation("ReviewAuthor", fields: [authorPersonaId], references: [id])

  targetPersona                   Persona                 @relation("ReviewTarget", fields: [targetPersonaId], references: [id])

  @@index([authorPersonaId])
  @@index([targetPersonaId])
  @@index([rating])
}

/// =========================================================
/// BLOCKS
/// =========================================================

model PersonaBlock {
  id                              String                  @id @default(uuid())

  blockerPersonaId                String
  blockedPersonaId                String

  reason                          String?

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  blockerPersona                  Persona                 @relation("PersonaBlocker", fields: [blockerPersonaId], references: [id])

  blockedPersona                  Persona                 @relation("PersonaBlocked", fields: [blockedPersonaId], references: [id])

  @@unique([blockerPersonaId, blockedPersonaId])

  @@index([blockerPersonaId])
  @@index([blockedPersonaId])
}

/// =========================================================
/// REPORTS
/// =========================================================

model PersonaReport {
  id                              String                  @id @default(uuid())

  reporterPersonaId               String
  targetPersonaId                 String

  category                        String

  description                     String?

  evidencePayload                 Json?

  moderationStatus                String?

  createdAt                       DateTime                @default(now())

  /// ---------- Relations ----------
  reporterPersona                 Persona                 @relation("PersonaReporter", fields: [reporterPersonaId], references: [id])

  targetPersona                   Persona                 @relation("PersonaReportTarget", fields: [targetPersonaId], references: [id])

  @@index([reporterPersonaId])
  @@index([targetPersonaId])
  @@index([category])
}

