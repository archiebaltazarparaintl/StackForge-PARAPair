  messageId                       String

  personaId                       String

  deliveredAt                     DateTime?
  seenAt                          DateTime?

  createdAt                       DateTime                      @default(now())

  /// ---------- Relations ----------
  message                         Message                       @relation(fields: [messageId], references: [id])

  persona                         Persona                       @relation(fields: [personaId], references: [id])

  @@unique([messageId, personaId])

  @@index([messageId])
  @@index([personaId])
  @@index([seenAt])
}

